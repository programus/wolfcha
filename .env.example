# =============================================================================
# WolfCha 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值，.env.local 不会被 Git 追踪。
# =============================================================================


# =============================================================================
# 站点访问保护
# 设置后，访客须输入正确密码才能进入站点。
# 修改密码后需重启服务，所有已有的登录 Cookie 将自动失效。
# 留空表示不启用密码保护。
# =============================================================================
SITE_PASSWORD=


# =============================================================================
# AI 提供商 — 选择以下一种或多种进行配置
# =============================================================================

# -----------------------------------------------------------------------------
# 1. ZenMux 聚合器（默认推荐，支持 OpenAI / Google / Anthropic / 等多家模型）
#    文档：https://zenmux.ai
# -----------------------------------------------------------------------------
ZENMUX_API_KEY=

# -----------------------------------------------------------------------------
# 2. 阿里云 DashScope / 百炼（Qwen、DeepSeek 等）
#    文档：https://dashscope.aliyuncs.com
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=

# -----------------------------------------------------------------------------
# 3. OpenAI 直连
#    支持模型：gpt-5.2 / gpt-5.2-pro / gpt-5-mini / gpt-5-nano / gpt-4.1
#    文档：https://platform.openai.com
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# 自定义接入端点（可用于代理或第三方兼容服务，默认无需修改）
# OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# 4. Google Gemini 直连（通过 OpenAI 兼容接口）
#    支持模型：gemini-3.1-pro-preview / gemini-3-flash-preview / gemini-2.5-pro 等
#    文档：https://ai.google.dev
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
# 自定义接入端点（默认无需修改）
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# -----------------------------------------------------------------------------
# 5. Anthropic 直连（通过 OpenAI 兼容接口）
#    支持模型：claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5
#    文档：https://www.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# 自定义接入端点（默认无需修改）
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# -----------------------------------------------------------------------------
# 6. 任意 OpenAI 兼容第三方服务
#    BASE_URL 必填；API_KEY 视服务商要求填写。
# -----------------------------------------------------------------------------
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=


# =============================================================================
# MiniMax TTS 语音合成（旁白语音功能）
#    文档：https://www.minimaxi.com
# =============================================================================
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# 接入端点（默认无需修改）
# MINIMAX_API_BASE_URL=https://api.minimaxi.com
# TTS 模型（默认无需修改）
# MINIMAX_TTS_MODEL=speech-01-turbo


# =============================================================================
# 默认模型配置（后端预设，前端可在设置页面覆盖）
# 用户首次访问时若尚未保存过模型设置，将自动应用以下默认值。
# 保存过设置的用户不受影响。
# =============================================================================

# 默认启用的模型列表（逗号分隔的模型 ID，留空表示不预设）
# 示例：DEFAULT_PLAYER_MODELS=gpt-5-mini,gemini-2.5-flash
DEFAULT_PLAYER_MODELS=

# 默认仅用于系统功能（角色生成/摘要/审核）的模型（逗号分隔，留空表示无）
DEFAULT_SYSTEM_ONLY_MODELS=

# 默认系统功能模型（留空表示自动选择）
DEFAULT_GENERATOR_MODEL=
DEFAULT_SUMMARY_MODEL=
DEFAULT_REVIEW_MODEL=


# =============================================================================
# 前端公开配置（NEXT_PUBLIC_ 前缀会暴露给浏览器端）
# =============================================================================

# 是否在开发模式下显示 DevTools 面板（true / false，默认 true）
# NEXT_PUBLIC_SHOW_DEVTOOLS=true

# 应用版本号 —— 由 next.config.ts 在构建时从 package.json 自动注入，无需手动设置
# NEXT_PUBLIC_APP_VERSION=